{
  "manifest_version": 3,
  "name": "AI Bug Reporter (DEV)",
  "version": "1.0.0",
  "description": "DEV build: debugger, broad host, optional notifications. Не для Web Store.",
  "permissions": [
    "storage",
    "scripting",
    "debugger",
    "tabs",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:*/*",
    "https://*/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+A", "mac": "Command+Shift+A" },
      "description": "Швидкий аналіз (відкрити popup)"
    },
    "take_screenshot": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "Скріншот для звіту"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:* https://* https://generativelanguage.googleapis.com https://api.openai.com;"
  }
}
